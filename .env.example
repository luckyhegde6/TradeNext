# Example env file
ENVIRONMENT=local
OPENROUTERKEY=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgress
POSTGRES_DB=tradenext
AUTH_SECRET="your-super-secret-random-string"
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=API_KEY
PORT=4000
INGEST_CSV_PATH=/data/sample_nse.csv
ADMIN_EMAIL=
ADMIN_PASSWORD=
DEMO_PASSWORD=

# ===========================================
# SEO & Analytics Configuration
# ===========================================

# Base URL for SEO (sitemap, canonical URLs)
# Production: https://tradenext6.netlify.app
NEXT_PUBLIC_BASE_URL=https://tradenext6.netlify.app

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics tracking
NEXT_PUBLIC_GA_ID=G-Z8KNHPZRHK

# Note: The GA ID is NOT a secret - it's designed to be public.
# However, only set NEXT_PUBLIC_ prefix for client-side variables.

# ===========================================
# Telegram Bot Configuration (Server-Only)
# ===========================================
# These are SERVER-ONLY env vars. Never expose to client side.
#
# TELEGRAM_SECRET — Bot token from @BotFather (format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)
# TELEGRAM_CHATID — Target chat/group/channel ID (numeric or @username)
# TELEGRAM_MESSAGEID — Optional message ID to edit instead of sending new messages
#
# How to get these:
#   1. Create a bot via @BotFather on Telegram → get the token
#   2. Add the bot to your group/channel
#   3. Send a message, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find chat_id
#   4. (Optional) Find message_id in getUpdates response to enable edit mode
#
# TELEGRAM_SECRET=
# TELEGRAM_CHATID=
# TELEGRAM_MESSAGEID=
