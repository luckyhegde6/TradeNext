# Example env file
ENVIRONMENT=local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgress
POSTGRES_DB=tradenext
AUTH_SECRET="your-super-secret-random-string"
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=API_KEY
PORT=4000
INGEST_CSV_PATH=/data/sample_nse.csv
ADMIN_EMAIL=
ADMIN_PASSWORD=
DEMO_PASSWORD=

# ===========================================
# SEO & Analytics Configuration
# ===========================================

# Base URL for SEO (sitemap, canonical URLs)
# Production: https://tradenext6.netlify.app
NEXT_PUBLIC_BASE_URL=https://tradenext6.netlify.app

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics tracking
NEXT_PUBLIC_GA_ID=G-Z8KNHPZRHK

# Note: The GA ID is NOT a secret - it's designed to be public.
# However, only set NEXT_PUBLIC_ prefix for client-side variables.
