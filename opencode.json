{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "coder": {
          "name": "qwen3-coder",
          "description": "Primary coding model for refactoring, writing code, debugging",
          "temperature": false
        },
        "assistant": {
          "name": "qwen2.5:3b",
          "description": "Fast general chat model for quick answers and summaries",
          "temperature": true
        },
        "reasoner": {
          "name": "deepseek-r1:7b",
          "description": "Complex reasoning, system design, algorithm thinking",
          "temperature": false
        },
        "planner": {
          "name": "deepseek-r1:1.5b",
          "description": "Lightweight reasoning for task planning and step generation",
          "temperature": false
        },
        "vision": {
          "name": "deepseek-ocr:3b",
          "description": "OCR and document extraction model",
          "temperature": false
        }
      }
    }
  },
  "server": {
    "port": 4096,
    "mdns": true
  },
  "lsp": {
    "typescript": {
      "enabled": true,
      "command": [
        "npx",
        "typescript-language-server",
        "--stdio"
      ]
    }
  },
  "plugin": [
    "opencode-helicone-session",
    "opencode-wakatime"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "Prisma-Remote": {
      "type": "remote",
      "url": "https://mcp.prisma.io/mcp",
      "enabled": false
    },
    "Prisma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "prisma",
        "mcp"
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true
    }
  },
  "permission": {
    "skill": {
      "*": "allow",
      "pr-review": "allow",
      "internal-*": "deny",
      "experimental-*": "ask"
    }
  }
}