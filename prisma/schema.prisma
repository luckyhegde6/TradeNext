// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  mobile String?
  password String?
  role     String  @default("user")
  
  // Verification fields
  isVerified             Boolean   @default(false)
  verificationCode       String?
  verificationExpiry     DateTime?
  verificationResendCount Int       @default(0)
  
  // Account status
  isBlocked              Boolean   @default(false)
  
  posts Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  portfolios Portfolio[] 
}

model Post {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  Int?
  author    User?    @relation(fields: [authorId], references: [id])
}

model Portfolio {
  id        String   @id @default(uuid())
  userId    Int
  name      String
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  transactions Transaction[]
  fundTransactions FundTransaction[]
}

model Transaction {
  id          String   @id @default(uuid())
  portfolioId String
  tradeDate   DateTime
  ticker      String
  side        String   // BUY | SELL
  quantity    Decimal  @db.Decimal(30,6)
  price       Decimal  @db.Decimal(30,6)
  fees        Decimal? @db.Decimal(30,6)
  notes       String?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id])
}

model FundTransaction {
  id          String   @id @default(uuid())
  portfolioId String
  type        String   // DEPOSIT | WITHDRAWAL
  amount      Decimal  @db.Decimal(30,6)
  date        DateTime @default(now())
  notes       String?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id])
}

model DailyPrice {
  ticker    String
  tradeDate DateTime
  open      Decimal? @db.Decimal(30,6)
  high      Decimal? @db.Decimal(30,6)
  low       Decimal? @db.Decimal(30,6)
  close     Decimal? @db.Decimal(30,6)
  volume    BigInt?
  vwap      Decimal? @db.Decimal(30,6)

  @@id([ticker, tradeDate])
  @@map("daily_prices")
}

model CorporateAction {
  id              Int      @id @default(autoincrement())
  symbol          String
  companyName     String
  series          String?  // EQ, GS, etc.
  subject         String?  // Original purpose text
  actionType      String   // DIVIDEND, SPLIT, BONUS, RIGHTS, BUYBACK, INTEREST
  exDate          DateTime?
  recordDate      DateTime?
  effectiveDate   DateTime?
  faceValue       String?  // Original face value
  oldFV           String?  // Old face value for splits (e.g., "10")
  newFV           String?  // New face value for splits (e.g., "2")
  ratio           String?  // e.g., "1:1" for bonus, "5:14" for rights
  dividendPerShare Decimal? @db.Decimal(30,6)
  dividendYield   Decimal? @db.Decimal(30,6)
  isin            String?
  bookClosureStartDate DateTime?
  bookClosureEndDate   DateTime?
  announcementDate DateTime? // Date of announcement
  source          String   @default("admin") // "admin" or "nse"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([symbol])
  @@index([exDate])
  @@index([actionType])
  @@index([source])
  @@unique([symbol, actionType, exDate])
  @@map("corporate_actions")
}

model InsiderTrading {
  id              Int      @id @default(autoincrement())
  symbol          String
  companyName     String
  acqName         String
  transactionType String
  securities      Decimal  @db.Decimal(30,2)
  price           Decimal? @db.Decimal(30,2)
  value           Decimal? @db.Decimal(30,2)
  secAcqPromoter  String?
  secType         String?
  afterSec        Decimal? @db.Decimal(30,2)
  mode             String?
  remarks         String?
  broadcastDate   DateTime?
  createdAt       DateTime  @default(now())
  
  @@index([symbol])
  @@index([broadcastDate])
  @@map("insider_trading")
}

model IndexClose {
  id        String   @id @default(uuid())
  indexName String
  asOf      DateTime
  open      Decimal? @db.Decimal(30,6)
  high      Decimal? @db.Decimal(30,6)
  low       Decimal? @db.Decimal(30,6)
  close     Decimal? @db.Decimal(30,6)
  vwap      Decimal? @db.Decimal(30,6)
  volume    BigInt?

  @@index([indexName, asOf])
  @@map("index_closes")
}

model IndexWeight {
  id        String  @id @default(uuid())
  indexName String
  ticker    String
  security  String?
  weight    Decimal? @db.Decimal(10,4)
  asOf      DateTime

  @@index([indexName, ticker, asOf])
  @@map("index_weights")
}

model Fundamental {
  ticker              String
  asOf                DateTime
  periodType          String
  revenue             Decimal? @db.Decimal(30,6)
  netIncome           Decimal? @db.Decimal(30,6)
  totalAssets         Decimal? @db.Decimal(30,6)
  totalLiabilities    Decimal? @db.Decimal(30,6)
  cash                Decimal? @db.Decimal(30,6)
  shareholdersEquity  Decimal? @db.Decimal(30,6)
  eps                 Decimal? @db.Decimal(30,6)
  peRatio             Decimal? @db.Decimal(30,6)
  roe                 Decimal? @db.Decimal(30,6)
  roic                Decimal? @db.Decimal(30,6)
  rawJson             Json?

  @@id([ticker, asOf, periodType])
  @@map("fundamentals")
}

model Index {
  id       String  @id @default(uuid())
  name     String  @unique
  display  String?
  createdAt DateTime @default(now())
}

model IndexPoint {
  id String @id @default(uuid())
  indexName String
  time DateTime
  open Decimal? @db.Decimal(30,6)
  high Decimal? @db.Decimal(30,6)
  low Decimal? @db.Decimal(30,6)
  close Decimal? @db.Decimal(30,6)
  volume BigInt?
  @@index([indexName, time])
}

model CorporateAnnouncement {
  id                String   @id @default(cuid())
  symbol            String
  companyName       String
  subject           String
  details           String?
  broadcastDateTime DateTime
  attachment        String?
  createdAt         DateTime @default(now())

  @@index([broadcastDateTime])
}

model IndexQuote {
  id              String   @id @default(cuid())
  indexName       String   @unique
  lastPrice       String
  change          String
  pChange         String
  open            String?
  high            String?
  low             String?
  previousClose   String?
  yearHigh        String?
  yearLow         String?
  peRatio         String?
  pbRatio         String?
  dividendYield   String?
  marketStatus    String?
  advances        Int?
  declines        Int?
  unchanged       Int?
  totalTradedVolume String?
  totalTradedValue  String?
  updatedAt       DateTime @updatedAt
  timestamp       DateTime @default(now())
}

model IndexHeatmapItem {
  id              String   @id @default(cuid())
  indexName       String
  symbol          String
  lastPrice       Decimal  @db.Decimal(30,6)
  change          Decimal  @db.Decimal(30,6)
  pChange         Decimal  @db.Decimal(30,6)
  volume          BigInt?
  value           Decimal? @db.Decimal(30,6)
  high            Decimal? @db.Decimal(30,6)
  low             Decimal? @db.Decimal(30,6)
  yearHigh        Decimal? @db.Decimal(30,6)
  yearLow         Decimal? @db.Decimal(30,6)
  updatedAt       DateTime @updatedAt

  @@unique([indexName, symbol])
  @@index([indexName])
}

model MarketSnapshot {
  id        String   @id @default(uuid())
  type      String   // gainers | losers | advance | deals
  payload   Json
  capturedAt DateTime @default(now())

  @@index([type, capturedAt])
}

model Alert {
  id        String   @id @default(uuid())
  userId    Int?
  type      String   // volume_spike | price_jump | price_above | price_below
  symbol    String?
  condition Json
  triggered Boolean  @default(false)
  triggeredAt DateTime?
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AIInsight {
  id        String   @id @default(uuid())
  snapshotId String
  summary   String
  createdAt DateTime @default(now())
}

model SavedScreen {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinancialScore {
  id              String   @id @default(uuid())
  symbol          String
  fScore          Int      @default(0)
  roa             Decimal? @db.Decimal(10,4)
  roaChange       Decimal? @db.Decimal(10,4)
  cfo             Decimal? @db.Decimal(10,4)
  cfoVsNi         Decimal? @db.Decimal(10,4)
  currentRatio    Decimal? @db.Decimal(10,4)
  currentRatioChg Decimal? @db.Decimal(10,4)
  leverage        Decimal? @db.Decimal(10,4)
  leverageChange  Decimal? @db.Decimal(10,4)
  sharesChange    Decimal? @db.Decimal(10,4)
  grossMargin     Decimal? @db.Decimal(10,4)
  marginChange    Decimal? @db.Decimal(10,4)
  assetTurnover   Decimal? @db.Decimal(10,4)
  turnoverChange  Decimal? @db.Decimal(10,4)
  periodType      String   @default("annual")
  asOf            DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([symbol, periodType, asOf])
  @@index([symbol])
  @@map("financial_scores")
}

model StockRecommendation {
  id              String   @id @default(uuid())
  symbol          String
  entryRange      String?
  shortTerm       String?
  longTerm        String?
  intraday        String?
  recommendation  String   // ACCUMULATE | BUY | HOLD | SELL | NEUTRAL
  analystRating   String?
  profitRangeMin  Decimal? @db.Decimal(30,2)
  profitRangeMax  Decimal? @db.Decimal(30,2)
  targetPrice     Decimal? @db.Decimal(30,2)
  analysis        String?
  imageUrl        String?
  isActive        Boolean  @default(true)
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   RecommendationSubscription[]

  @@index([symbol])
  @@index([isActive])
  @@map("stock_recommendations")
}

model UserAlert {
  id              String   @id @default(uuid())
  userId          Int
  symbol          String?
  alertType       String   // price_above | price_below | volume_spike | custom
  title           String
  message         String?
  targetPrice     Decimal? @db.Decimal(30,2)
  currentPrice    Decimal? @db.Decimal(30,2)
  status          String   @default("active") // active | triggered | dismissed
  triggeredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("user_alerts")
}

model RecommendationSubscription {
  id                String   @id @default(uuid())
  userId            Int
  recommendationId  String
  createdAt        DateTime @default(now())

  recommendation    StockRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([userId, recommendationId])
  @@index([userId])
  @@index([recommendationId])
  @@map("recommendation_subscriptions")
}

model Watchlist {
  id          String   @id @default(uuid())
  userId      Int
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       WatchlistItem[]

  @@index([userId])
  @@map("watchlists")
}

model WatchlistItem {
  id          String   @id @default(uuid())
  watchlistId String
  symbol      String
  addedAt     DateTime @default(now())

  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@index([watchlistId])
  @@index([symbol])
  @@map("watchlist_items")
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          Int?
  userEmail       String?
  action          String   // API_CALL | USER_ACTION | PORTFOLIO_ACTION | NSE_CALL | LOGIN | LOGOUT
  resource        String?
  resourceId      String?
  method          String?
  path            String?
  requestBody     Json?
  responseStatus  Int?
  responseTime    Int?     // milliseconds
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  nseEndpoint     String?
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource])
   @@map("audit_logs")
}

model RateLimit {
  id              String   @id @default(uuid())
  userId          Int
  endpoint        String
  requestCount    Int      @default(0)
  windowStart     DateTime @default(now())
  isFlagged       Boolean  @default(false)
  lastRequestAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([isFlagged])
  @@map("rate_limits")
}

model AdminAnnouncement {
  id              Int      @id @default(autoincrement())
  title           String
  message         String
  type            String   // info | warning | error | success
  target          String   // all | user | admin
  isActive        Boolean  @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  link            String?
  createdBy       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@index([target])
  @@map("admin_announcements")
}

model Notification {
  id          String    @id @default(uuid())
  userId      Int
  type        String    // alert_triggered | recommendation | system | watchlist | contact_message
  title       String
  message     String
  link        String?
  isRead      Boolean   @default(false)
  isAddressed Boolean   @default(false)
  addressedAt DateTime?
  addressedBy Int?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([isAddressed])
  @@index([createdAt])
  @@map("notifications")
}

model Symbol {
  id          Int      @id @default(autoincrement())
  symbol      String   @unique
  companyName String
  series      String?
  industry    String?
  isActive    Boolean  @default(true)
  lastPrice   Decimal? @db.Decimal(30,6)
  lastUpdated DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("symbols")
  @@index([symbol])
  @@index([companyName])
}

model BlockDeal {
  id              Int      @id @default(autoincrement())
  date            DateTime
  symbol          String
  securityName    String
  clientName      String
  buySell         String
  quantityTraded  Int
  tradePrice      Float
  remarks         String?
  importedAt      DateTime @default(now())

  @@index([date])
  @@index([symbol])
  @@map("block_deals")
}

model BulkDeal {
  id              Int      @id @default(autoincrement())
  date            DateTime
  symbol          String
  securityName    String
  clientName      String
  buySell         String
  quantityTraded  Int
  tradePrice      Float
  remarks         String?
  importedAt      DateTime @default(now())

  @@index([date])
  @@index([symbol])
  @@map("bulk_deals")
}

model ShortSelling {
  id              Int      @id @default(autoincrement())
  date            DateTime
  symbol          String
  securityName    String
  quantity        Int
  importedAt      DateTime @default(now())

  @@index([date])
  @@index([symbol])
  @@map("short_selling")
}

// ============================================
// Task Scheduling & Worker Models
// ============================================

model CronJob {
  id            String    @id @default(uuid())
  name          String
  description   String?
  taskType     String    // stock_sync | corp_actions | alert_check | screener | recommendations
  cronExpression String
  isActive      Boolean   @default(true)
  lastRun       DateTime?
  nextRun       DateTime?
  runCount      Int       @default(0)
  successCount  Int       @default(0)
  failureCount  Int       @default(0)
  config        Json?     // Additional config for the task
  createdBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskType])
  @@index([isActive])
  @@map("cron_jobs")
}

model WorkerTask {
  id            String    @id @default(uuid())
  name          String
  taskType      String    // alert_check | screener | recommendations | data_sync | cleanup
  taskCategory  String    @default("regular") // cron | async | regular
  status        String    @default("pending") // pending | running | completed | failed | cancelled
  priority      Int       @default(5) // 1-10, higher = more urgent
  payload       Json?     // Task-specific data
  result        Json?     // Result of the task execution
  error         String?   // Error message if failed
  startedAt     DateTime?
  completedAt   DateTime?
  retryCount    Int       @default(0)
  maxRetries   Int       @default(3)
  createdBy     Int?
  assignedTo    String?   // Worker node identifier
  cronJobId     String?   // Reference to CronJob if created from cron
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([taskType])
  @@index([taskCategory])
  @@index([priority])
  @@index([createdAt])
  @@map("worker_tasks")
}

model WorkerStatus {
  id              String    @id @default(uuid())
  workerId        String    @unique // Unique worker identifier
  workerName      String?
  status          String    @default("idle") // idle | busy | offline
  currentTaskId   String?
  tasksCompleted  Int       @default(0)
  tasksFailed     Int       @default(0)
  lastHeartbeat  DateTime  @default(now())
  cpuUsage        Float?
  memoryUsage    Float?
  createdAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("worker_status")
}

// ============================================
// Enhanced Symbol with Daily Snapshot
// ============================================

model StockSnapshot {
  id              String    @id @default(uuid())
  symbol          String
  companyName     String?
  lastPrice       Decimal?  @db.Decimal(30,6)
  change          Decimal?  @db.Decimal(30,6)
  pChange         Decimal?  @db.Decimal(30,6)
  open            Decimal?  @db.Decimal(30,6)
  high            Decimal?  @db.Decimal(30,6)
  low             Decimal?  @db.Decimal(30,6)
  previousClose   Decimal?  @db.Decimal(30,6)
  volume          BigInt?
  value           Decimal?  @db.Decimal(30,6)
  yearHigh        Decimal?  @db.Decimal(30,6)
  yearLow         Decimal?  @db.Decimal(30,6)
  pe              Decimal?  @db.Decimal(30,6)
  pb              Decimal?  @db.Decimal(30,6)
  dividendYield   Decimal?  @db.Decimal(30,6)
  sector          String?
  industry        String?
  marketCap       Decimal?  @db.Decimal(30,6)
  capturedAt      DateTime  @default(now())

  @@unique([symbol, capturedAt])
  @@index([symbol])
  @@index([capturedAt])
  @@map("stock_snapshots")
}

// ============================================
// Screener Models
// ============================================

model ScreenerConfig {
  id              String    @id @default(uuid())
  name            String
  description     String?
  filters         Json      // Filter criteria
  isDefault       Boolean   @default(false)
  isPublic       Boolean   @default(true)
  userId          Int?
  lastRun         DateTime?
  lastResultCount Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@map("screener_configs")
}

model ScreenerResult {
  id              String    @id @default(uuid())
  configId        String
  symbol          String
  companyName     String?
  lastPrice       Decimal?  @db.Decimal(30,6)
  change          Decimal?  @db.Decimal(30,6)
  pChange         Decimal?  @db.Decimal(30,6)
  volume          BigInt?
  avgVolume       BigInt?
  marketCap       Decimal?  @db.Decimal(30,6)
  peRatio         Decimal?  @db.Decimal(30,6)
  pbRatio         Decimal?  @db.Decimal(30,6)
  roe             Decimal?  @db.Decimal(30,6)
  debtToEquity    Decimal?  @db.Decimal(30,6)
  eps             Decimal?  @db.Decimal(30,6)
  bookValue       Decimal?  @db.Decimal(30,6)
  dividendYield   Decimal?  @db.Decimal(30,6)
  sector          String?
  industry        String?
  technicalRating String?
  analystRating   String?
  createdAt       DateTime  @default(now())

  @@index([configId])
  @@index([symbol])
  @@index([createdAt])
  @@map("screener_results")
}